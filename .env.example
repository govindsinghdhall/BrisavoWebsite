MONGODB_URI=mongodb://127.0.0.1:27017/brisavo
MONGODB_DB=brisavo
JWT_SECRET=replace-with-a-long-random-secret

# Outstatic
# Use an Outstatic API key (recommended) or configure GitHub OAuth below.
OUTSTATIC_API_KEY=ost_replace-with-your-outstatic-api-key
OST_TOKEN_SECRET=replace-with-a-random-32-character-secret

# Required when using local GitHub OAuth, or when Outstatic cannot infer the repo.
OST_GITHUB_ID=
OST_GITHUB_SECRET=
OST_REPO_OWNER=
OST_REPO_SLUG=
OST_REPO_BRANCH=main

# Optional media locations. Configure these in Outstatic's Media Library if needed.
# OST_REPO_MEDIA_PATH=public/images
# OST_PUBLIC_MEDIA_PATH=/images
