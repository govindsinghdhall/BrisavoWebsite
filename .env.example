MONGODB_URI=mongodb://127.0.0.1:27017/brisavo
MONGODB_DB=brisavo
JWT_SECRET=replace-with-a-long-random-secret

# Site
NEXT_PUBLIC_SITE_URL=https://brisavo.com

# Keystatic
# Local development uses filesystem storage by default (KEYSTATIC_STORAGE_KIND=local).
# For production on Vercel, set KEYSTATIC_STORAGE_KIND=github and configure the repo.
KEYSTATIC_STORAGE_KIND=local
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=
KEYSTATIC_BRANCH_PREFIX=

# Generated by Keystatic when connecting GitHub mode in the Admin UI:
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Optional: use GitHub reader at runtime instead of local files
# KEYSTATIC_READER_MODE=github
# KEYSTATIC_GITHUB_TOKEN=
# GITHUB_PAT=
